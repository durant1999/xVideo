# Copy to .env on the GPU server and fill in. The BFF reads these at startup.

# Generate once:  python -c "import secrets; print(secrets.token_urlsafe(32))"
XVIDEO_API_TOKEN=replace-with-a-long-random-token

# Bind loopback only — reached via the SSH LocalForward, never public.
XVIDEO_HOST=127.0.0.1
XVIDEO_PORT=8788

# Phase 0: leave unset/0 (only /healthz + /ping). Phase 1: set to 1 to mount job routes.
XVIDEO_ENABLE_JOBS=0

# Optional. Defaults to the xVideo repo root when this server/ folder lives in the repo.
# Set this only if the BFF is deployed outside the xVideo checkout.
# XVIDEO_REPO_ROOT=/path/to/xVideo
XVIDEO_JOB_ROOT=runs/mcp_jobs
XVIDEO_CONFIG_PATH=configs/pipeline.yaml

# Default 0: successful jobs delete source video, frames, and audio.wav after text artifacts are ready.
# Set to 1 when debugging or when the app needs original media/frames after completion.
XVIDEO_KEEP_MEDIA=0
